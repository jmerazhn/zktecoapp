<Window x:Class="ZKTecoManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZKTeco Manager" Height="720" Width="1280"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,28,20,20">
                    <StackPanel>
                        <TextBlock Text="ZKTeco" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Manager" FontSize="13" Foreground="#8BAFD4"/>
                    </StackPanel>
                </Border>

                <Separator DockPanel.Dock="Top" Background="#2A4A6E" Margin="0"/>

                <!-- Nav -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8">
                    <Button x:Name="BtnDevices"   Content="  Dispositivos"  Tag="Devices"   Style="{StaticResource NavButton}" Click="Nav_Click"/>
                    <Button x:Name="BtnEmployees" Content="  Empleados"     Tag="Employees" Style="{StaticResource NavButton}" Click="Nav_Click"/>
                    <Button x:Name="BtnAttendance" Content="  Asistencia"   Tag="Attendance" Style="{StaticResource NavButton}" Click="Nav_Click"/>
                    <Button x:Name="BtnIncidents" Content="  Incidencias"   Tag="Incidents" Style="{StaticResource NavButton}" Click="Nav_Click"/>
                    <Button x:Name="BtnReports"   Content="  Reportes"      Tag="Reports"   Style="{StaticResource NavButton}" Click="Nav_Click"/>
                </StackPanel>

                <!-- Settings button at bottom -->
                <Button DockPanel.Dock="Bottom"
                        Content="  Conexión BD" Tag="DbSettings"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Margin="0,0,0,4"/>

                <!-- Version at bottom -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0"
                           Foreground="#4A6A8A" FontSize="11"
                           Margin="20,0,0,8" VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <!-- ── Content ── -->
        <Border Grid.Column="1" Padding="28">
            <ContentControl x:Name="MainContent">
                <!-- Welcome screen -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Bienvenido a ZKTeco Manager"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Selecciona un módulo del menú lateral para comenzar."
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </ContentControl>
        </Border>
    </Grid>
</Window>
