<UserControl x:Class="ZKTecoManager.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Reportes" Style="{StaticResource SectionHeader}" Margin="0"/>
            <TextBlock Text="Genera reportes de asistencia en Excel o PDF"
                       Style="{StaticResource FieldLabel}" Margin="0"/>
        </StackPanel>

        <!-- ── Config card ── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="24">
            <StackPanel>

                <!-- Report type -->
                <TextBlock Text="Tipo de reporte" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton Content="Detalle de Asistencia" FontSize="13"
                                 IsChecked="{Binding IsDetailType}" Margin="0,0,24,0"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                    <RadioButton Content="Resumen Mensual" FontSize="13"
                                 IsChecked="{Binding IsSummaryType}"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Filters grid -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Empresa"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Departamento"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Empleado"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>

                    <!-- Inputs -->
                    <ComboBox Grid.Row="2" Grid.Column="0"
                              ItemsSource="{Binding Companies}"
                              SelectedItem="{Binding SelectedCompany}"
                              DisplayMemberPath="Name"
                              Padding="10,8" FontSize="13"/>

                    <ComboBox Grid.Row="2" Grid.Column="2"
                              ItemsSource="{Binding Departments}"
                              SelectedItem="{Binding SelectedDepartment}"
                              DisplayMemberPath="Name"
                              Padding="10,8" FontSize="13"/>

                    <ComboBox Grid.Row="2" Grid.Column="4"
                              ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee}"
                              DisplayMemberPath="FullName"
                              Padding="10,8" FontSize="13"/>
                </Grid>

                <!-- Date range -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Fecha desde"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Fecha hasta"
                               Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>

                    <DatePicker Grid.Row="2" Grid.Column="0"
                                SelectedDate="{Binding DateFrom}"
                                SelectedDateFormat="Short" Padding="8,7" FontSize="13"/>

                    <DatePicker Grid.Row="2" Grid.Column="2"
                                SelectedDate="{Binding DateTo}"
                                SelectedDateFormat="Short" Padding="8,7" FontSize="13"/>
                </Grid>

                <!-- Export buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Exportar Excel" Height="40" Padding="20,0" Margin="0,0,12,0"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ExportExcelCommand}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊 " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Exportar Excel" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button Content="Exportar PDF" Height="40" Padding="20,0"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ExportPdfCommand}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄 " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Exportar PDF" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="4" HorizontalAlignment="Right" Width="120"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
