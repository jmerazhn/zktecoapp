<Window x:Class="ZKTecoManager.Views.Dialogs.ProcessAttendanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Procesar Asistencia" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <StackPanel Margin="24">

        <TextBlock Text="Procesar Registros de Asistencia"
                   Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
        <TextBlock Text="Se calcularán horas, tardanzas y horas extra a partir de los logs crudos del reloj."
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,20"/>

        <!-- Empresa -->
        <TextBlock Text="Empresa" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="CmbCompany" DisplayMemberPath="Name"
                  Padding="8,6" FontSize="13" Margin="0,0,0,14"/>

        <!-- Rango de fechas -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Fecha inicio *" Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="DpFrom" SelectedDateFormat="Short" Padding="6,5" FontSize="13"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Fecha fin *" Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="DpTo" SelectedDateFormat="Short" Padding="6,5" FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Info box -->
        <Border Background="#FFF8E7" BorderBrush="#F59E0B" BorderThickness="1"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠ " Foreground="#D97706" FontSize="13"/>
                <TextBlock Text="Solo se procesarán logs sin procesar. Los registros con estado Justificado o Descanso no se sobreescriben."
                           Foreground="#92400E" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Error -->
        <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}"
                   FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="90" Height="34" Margin="0,0,8,0" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E5E7EB" CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Procesar" Width="90" Height="34"
                    Style="{StaticResource AccentButton}" Click="Process_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
