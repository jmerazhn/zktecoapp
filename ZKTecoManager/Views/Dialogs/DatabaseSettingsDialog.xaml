<Window x:Class="ZKTecoManager.Views.Dialogs.DatabaseSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de Base de Datos" Width="520"
        SizeToContent="Height" MinHeight="320"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <!-- Outer layout: buttons always docked at bottom, content scrolls above -->
    <DockPanel Margin="28">

        <!-- ── Buttons — always visible at bottom ── -->
        <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Probar conexión" Height="38" Padding="16,0"
                    Style="{StaticResource PrimaryButton}" Click="Test_Click"/>

            <Button Grid.Column="2" Content="Cancelar" Height="38" Width="100"
                    Style="{StaticResource PrimaryButton}" Click="Cancel_Click"/>
            <Button Grid.Column="4" Content="Guardar" Height="38" Width="100"
                    Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </Grid>

        <!-- ── Form content ── -->
        <StackPanel>

            <!-- Title -->
            <TextBlock Text="Conexión a Base de Datos" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Configure el servidor y las credenciales de acceso"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,20"/>

            <!-- Server -->
            <TextBlock Text="Servidor" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource ModernTextBox}"
                     Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13"/>
            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,14"
                       Text="Ej: localhost · localhost\SQLEXPRESS · (localdb)\MSSQLLocalDB · 192.168.1.10"/>

            <!-- Database -->
            <TextBlock Text="Base de datos" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource ModernTextBox}"
                     Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13" Margin="0,0,0,14"/>

            <!-- Auth type -->
            <TextBlock Text="Autenticación" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <RadioButton Content="Windows (Integrated Security)" FontSize="13"
                             IsChecked="{Binding IsWindowsAuth}"
                             Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,24,0"/>
                <RadioButton Content="SQL Server (usuario y contraseña)" FontSize="13"
                             IsChecked="{Binding IsSqlAuth}"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>

            <!-- SQL Server credentials (shown only when SQL auth selected) -->
            <Grid Visibility="{Binding IsSqlAuth, Converter={StaticResource BoolToVisibilityConverter}}"
                  Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Usuario" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <PasswordBox x:Name="PwdBox"
                                     BorderThickness="0" Padding="10,8" FontSize="13"
                                     Background="Transparent"
                                     PasswordChanged="PwdBox_PasswordChanged"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Test result -->
            <Border x:Name="TestResultBorder" CornerRadius="6" Padding="12,8"
                    Margin="0,0,0,14" Visibility="Collapsed">
                <TextBlock x:Name="TestResultText" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Connection string preview -->
            <TextBlock Text="Vista previa" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="10,8">
                <TextBlock x:Name="ConnStrPreview" FontSize="11" FontFamily="Consolas"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </DockPanel>
</Window>
