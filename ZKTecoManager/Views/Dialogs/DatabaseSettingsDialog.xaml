<Window x:Class="ZKTecoManager.Views.Dialogs.DatabaseSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración de Base de Datos" Width="520" Height="480"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Conexión a Base de Datos" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Configure el servidor y las credenciales de acceso"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Server -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Servidor" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtServer" Style="{StaticResource ModernTextBox}"
                     Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13"/>
            <TextBlock Text="Ejemplos: localhost · localhost\SQLEXPRESS · (localdb)\MSSQLLocalDB · 192.168.1.10"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Database -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Base de datos" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource ModernTextBox}"
                     Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13"/>
        </StackPanel>

        <!-- Auth type -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="Autenticación" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Windows (Integrated Security)" FontSize="13"
                             IsChecked="{Binding IsWindowsAuth}"
                             Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,24,0"/>
                <RadioButton Content="SQL Server (usuario y contraseña)" FontSize="13"
                             IsChecked="{Binding IsSqlAuth}"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- SQL Server credentials -->
        <Grid Grid.Row="8"
              Visibility="{Binding IsSqlAuth, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Usuario"
                       Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Contraseña"
                       Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>

            <TextBox Grid.Row="2" Grid.Column="0"
                     Style="{StaticResource ModernTextBox}"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13"/>

            <Border Grid.Row="2" Grid.Column="2"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6">
                <PasswordBox x:Name="PwdBox"
                             BorderThickness="0" Padding="10,8" FontSize="13"
                             Background="Transparent"
                             PasswordChanged="PwdBox_PasswordChanged"/>
            </Border>
        </Grid>

        <!-- Test result -->
        <Border Grid.Row="10" x:Name="TestResultBorder" CornerRadius="6" Padding="12,8"
                Visibility="Collapsed">
            <TextBlock x:Name="TestResultText" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Connection string preview -->
        <StackPanel Grid.Row="12">
            <TextBlock Text="Vista previa de la conexión" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="10,8">
                <TextBlock x:Name="ConnStrPreview" FontSize="11" FontFamily="Consolas"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Probar conexión" Height="38" Padding="16,0"
                    Style="{StaticResource PrimaryButton}" Click="Test_Click"/>

            <Button Grid.Column="2" Content="Cancelar" Height="38" Width="100"
                    Style="{StaticResource PrimaryButton}" Click="Cancel_Click"/>
            <Button Grid.Column="4" Content="Guardar" Height="38" Width="100"
                    Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
