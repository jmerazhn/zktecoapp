<Window x:Class="ZKTecoManager.Views.Dialogs.EmployeeFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Empleado" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <TextBlock x:Name="TitleText" Text="Agregar Empleado"
                   Style="{StaticResource SectionHeader}" Margin="0,0,0,20"/>

        <!-- Empresa / Departamento -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Empresa *"/>
                <ComboBox x:Name="CmbCompany" DisplayMemberPath="Name"
                          Padding="8,6" FontSize="13"
                          SelectionChanged="CmbCompany_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Departamento"/>
                <ComboBox x:Name="CmbDepartment" DisplayMemberPath="Name"
                          Padding="8,6" FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Código -->
        <Label Content="Código de empleado *"/>
        <TextBox x:Name="TxtCode" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

        <!-- Nombre / Apellido -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Nombre(s) *"/>
                <TextBox x:Name="TxtFirstName" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Apellido(s) *"/>
                <TextBox x:Name="TxtLastName" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
        </Grid>

        <!-- Puesto / Fecha ingreso -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Puesto"/>
                <TextBox x:Name="TxtPosition" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Fecha de ingreso"/>
                <DatePicker x:Name="DpHireDate" FontSize="13"
                            SelectedDateFormat="Short" Padding="6,5"/>
            </StackPanel>
        </Grid>

        <!-- Tarjeta RFID -->
        <Label Content="Número de tarjeta RFID"/>
        <TextBox x:Name="TxtCard" Style="{StaticResource ModernTextBox}" Margin="0,0,0,24"/>

        <!-- Error -->
        <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}"
                   FontSize="12" Margin="0,0,0,12" Visibility="Collapsed" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="90" Height="34" Margin="0,0,8,0" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E5E7EB" CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Guardar" Width="90" Height="34"
                    Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
