<Window x:Class="ZKTecoManager.Views.Dialogs.DeviceFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dispositivo" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <TextBlock x:Name="TitleText" Text="Agregar Dispositivo"
                   Style="{StaticResource SectionHeader}" Margin="0,0,0,20"/>

        <!-- Nombre -->
        <Label Content="Nombre *"/>
        <TextBox x:Name="TxtName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

        <!-- Empresa -->
        <Label Content="Empresa *"/>
        <ComboBox x:Name="CmbCompany" DisplayMemberPath="Name"
                  Padding="8,6" FontSize="13" Margin="0,0,0,14"/>

        <!-- IP y Puerto -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Dirección IP *"/>
                <TextBox x:Name="TxtIp" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Puerto *"/>
                <TextBox x:Name="TxtPort" Style="{StaticResource ModernTextBox}" Text="4370"/>
            </StackPanel>
        </Grid>

        <!-- Contraseña de comunicación -->
        <Label Content="Contraseña de comunicación"/>
        <TextBox x:Name="TxtPassword" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

        <!-- Ubicación -->
        <Label Content="Ubicación"/>
        <TextBox x:Name="TxtLocation" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

        <!-- Modelo -->
        <Label Content="Modelo"/>
        <TextBox x:Name="TxtModel" Style="{StaticResource ModernTextBox}" Margin="0,0,0,24"/>

        <!-- Error message -->
        <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}"
                   FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="90" Height="34" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="{StaticResource BorderBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Guardar" Width="90" Height="34"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
