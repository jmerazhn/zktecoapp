<Window x:Class="ZKTecoManager.Views.Dialogs.IncidentFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Incidencia" Width="480" Height="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"/>

        <!-- Empleado -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Empleado" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbEmployee"
                      ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee}"
                      DisplayMemberPath="FullName"
                      Padding="10,8" FontSize="13"/>
        </StackPanel>

        <!-- Fecha -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Fecha de incidencia" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <DatePicker SelectedDate="{Binding IncidentDate}"
                        SelectedDateFormat="Short" Padding="8,7" FontSize="13"/>
        </StackPanel>

        <!-- Tipo -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="Tipo de incidencia" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding IncidentTypes}"
                      SelectedItem="{Binding SelectedIncidentType}"
                      DisplayMemberPath="Label"
                      Padding="10,8" FontSize="13"/>
        </StackPanel>

        <!-- Descripción -->
        <StackPanel Grid.Row="8">
            <TextBlock Text="Descripción (opcional)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBox}"
                     Height="64" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalContentAlignment="Top" Padding="10,8" FontSize="13"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Height="36" Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButton}" Click="Cancel_Click"/>
            <Button Content="Guardar" Width="100" Height="36"
                    Style="{StaticResource AccentButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
