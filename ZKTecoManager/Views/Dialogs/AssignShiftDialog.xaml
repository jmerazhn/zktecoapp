<Window x:Class="ZKTecoManager.Views.Dialogs.AssignShiftDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asignar Turno" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <StackPanel Margin="24">

        <TextBlock Text="Asignar Turno" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
        <TextBlock x:Name="TxtEmployeeName" FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

        <!-- Current shift -->
        <Border Background="#F0F4FF" CornerRadius="6" Padding="12,10" Margin="0,0,0,18">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Turno actual: " FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock x:Name="TxtCurrentShift" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- New shift -->
        <TextBlock Text="Nuevo turno *" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="CmbShift" DisplayMemberPath="Name"
                  Padding="8,6" FontSize="13" Margin="0,0,0,14"/>

        <!-- Effective from -->
        <TextBlock Text="Vigente desde *" Style="{StaticResource FieldLabel}"/>
        <DatePicker x:Name="DpEffectiveFrom" FontSize="13"
                    SelectedDateFormat="Short" Padding="6,5" Margin="0,0,0,24"/>

        <!-- Error -->
        <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}"
                   FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="90" Height="34" Margin="0,0,8,0" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E5E7EB" CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Asignar" Width="90" Height="34"
                    Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
