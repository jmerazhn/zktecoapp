<UserControl x:Class="ZKTecoManager.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Gestión de Empleados" Style="{StaticResource SectionHeader}" Margin="0"/>
                <TextBlock Text="Administración de personal y enrolamiento en relojes"
                           Style="{StaticResource FieldLabel}" Margin="0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Agregar Empleado" Height="34" Padding="14,0"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding AddCommand}" VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Filters ── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Companies}"
                          SelectedItem="{Binding SelectedCompany}"
                          DisplayMemberPath="Name"
                          Padding="8,6" FontSize="13">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Departments}"
                          SelectedItem="{Binding SelectedDepartment}"
                          DisplayMemberPath="Name"
                          Padding="8,6" FontSize="13">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <TextBox Grid.Column="4"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}">
                    <TextBox.Resources>
                        <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  Buscar por nombre, código o tarjeta..."
                                                               Foreground="#9CA3AF" FontSize="13"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <CheckBox Grid.Column="6" Content="Mostrar inactivos"
                          IsChecked="{Binding ShowInactive}"
                          VerticalAlignment="Center" FontSize="12"/>

                <Button Grid.Column="8" Content="Buscar" Height="34" Width="80"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadCommand}"/>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                      IsReadOnly="True">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"      Binding="{Binding Code}"        Width="80"/>
                    <DataGridTextColumn Header="Apellido(s)" Binding="{Binding LastName}"     Width="130"/>
                    <DataGridTextColumn Header="Nombre(s)"   Binding="{Binding FirstName}"    Width="120"/>
                    <DataGridTextColumn Header="Departamento" Binding="{Binding Department}"  Width="120"/>
                    <DataGridTextColumn Header="Puesto"      Binding="{Binding Position}"     Width="110"/>
                    <DataGridTextColumn Header="Tarjeta"     Binding="{Binding CardDisplay}"  Width="90"/>
                    <DataGridTextColumn Header="Turno"       Binding="{Binding CurrentShift}" Width="100"/>
                    <DataGridTextColumn Header="Relojes"     Binding="{Binding DevicesDisplay}" Width="80"/>

                    <!-- Estado badge -->
                    <DataGridTemplateColumn Header="Estado" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="7,2" HorizontalAlignment="Left" Margin="6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#22C55E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#6B7280"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ActiveLabel}" FontSize="11" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Acciones -->
                    <DataGridTemplateColumn Header="Acciones" Width="*" MinWidth="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="6,4" VerticalAlignment="Center">

                                    <Button Content="Editar" Width="60" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource PrimaryButton}" FontSize="11"
                                            Command="{Binding DataContext.EditCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"/>

                                    <Button Content="Turno" Width="58" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource PrimaryButton}" FontSize="11"
                                            Command="{Binding DataContext.AssignShiftCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"/>

                                    <Button Content="Relojes" Width="64" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource AccentButton}" FontSize="11"
                                            Command="{Binding DataContext.ManageDevicesCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"/>

                                    <Button Width="26" Height="26" FontSize="11" ToolTip="Activar / Desactivar"
                                            Command="{Binding DataContext.ToggleActiveCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                <Setter Property="Content" Value="✕"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Content" Value="✔"/>
                                                        <Setter Property="Background" Value="#22C55E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Status bar ── -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Employees.Count, StringFormat='{}{0} empleado(s)'}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="  ·  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Height="4"
                             HorizontalAlignment="Right" Width="120"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
