<UserControl x:Class="ZKTecoManager.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ZKTecoManager.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header toolbar -->
        <Border Grid.Row="0" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gestión de Dispositivos" Style="{StaticResource SectionHeader}" Margin="0"/>
                    <TextBlock Text="Relojes ZKTeco registrados en el sistema"
                               Style="{StaticResource FieldLabel}" Margin="0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Actualizar" Width="100" Height="34" Margin="0,0,8,0"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                    <Button Content="+ Agregar" Width="100" Height="34"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource AccentButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="DeviceGrid"
                      Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Devices}"
                      SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <!-- Status dot -->
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="10" Height="10" Margin="14,0"
                                         Fill="{Binding StatusBrush}"
                                         VerticalAlignment="Center">
                                    <Ellipse.ToolTip>
                                        <ToolTip Content="{Binding StatusLabel}"/>
                                    </Ellipse.ToolTip>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Nombre"    Binding="{Binding Name}"        Width="150"/>
                    <DataGridTextColumn Header="Empresa"   Binding="{Binding CompanyName}" Width="120"/>
                    <DataGridTextColumn Header="IP"        Binding="{Binding IpAddress}"   Width="120"/>
                    <DataGridTextColumn Header="Puerto"    Binding="{Binding Port}"         Width="65"/>
                    <DataGridTextColumn Header="Ubicación" Binding="{Binding Location}"    Width="130"/>
                    <DataGridTextColumn Header="Modelo"    Binding="{Binding Model}"        Width="110"/>
                    <DataGridTextColumn Header="Último Sync" Binding="{Binding LastSyncDisplay}" Width="140"/>

                    <!-- Actions column -->
                    <DataGridTemplateColumn Header="Acciones" Width="*" MinWidth="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,4" VerticalAlignment="Center">

                                    <Button Content="Probar" Width="62" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource PrimaryButton}"
                                            FontSize="11"
                                            Command="{Binding DataContext.TestConnectionCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="Descargar" Width="74" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource PrimaryButton}"
                                            FontSize="11"
                                            Command="{Binding DataContext.DownloadLogsCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="Sincronizar" Width="80" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource PrimaryButton}"
                                            FontSize="11"
                                            Command="{Binding DataContext.SyncInfoCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="Editar" Width="58" Height="26" Margin="0,0,4,0"
                                            Style="{StaticResource AccentButton}"
                                            FontSize="11"
                                            Command="{Binding DataContext.EditCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="Eliminar" Width="65" Height="26"
                                            Style="{StaticResource DangerButton}"
                                            FontSize="11"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="4"
                             HorizontalAlignment="Right" Width="120"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
