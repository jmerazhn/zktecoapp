<UserControl x:Class="ZKTecoManager.Views.IncidentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Incidencias" Style="{StaticResource SectionHeader}" Margin="0"/>
                <TextBlock Text="Permisos, enfermedades, vacaciones y justificantes"
                           Style="{StaticResource FieldLabel}" Margin="0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Aprobar" Height="34" Padding="14,0" Margin="0,0,8,0"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding ApproveCommand}"/>
                <Button Content="Editar" Height="34" Padding="14,0" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding EditCommand}"/>
                <Button Content="Eliminar" Height="34" Padding="14,0" Margin="0,0,8,0"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"/>
                <Button Content="+ Nueva" Height="34" Padding="14,0"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding AddCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ── Filters ── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Empresa:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding Companies}"
                          SelectedItem="{Binding SelectedCompany}"
                          DisplayMemberPath="Name" Width="200"
                          Padding="8,6" FontSize="12" Margin="0,0,16,0"/>

                <TextBlock Text="Desde:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DateFrom}"
                            SelectedDateFormat="Short" Width="120"
                            Padding="6,5" FontSize="12" Margin="0,0,16,0"/>

                <TextBlock Text="Hasta:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DateTo}"
                            SelectedDateFormat="Short" Width="120"
                            Padding="6,5" FontSize="12" Margin="0,0,16,0"/>

                <Button Content="Buscar" Height="34" Width="80"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadCommand}"/>
            </StackPanel>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Incidents}"
                      SelectedItem="{Binding SelectedIncident, Mode=TwoWay}"
                      IsReadOnly="True" RowHeight="38">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha"       Binding="{Binding DateDisplay}"  Width="90"/>
                    <DataGridTextColumn Header="Código"      Binding="{Binding EmployeeCode}" Width="70"/>
                    <DataGridTextColumn Header="Nombre"      Binding="{Binding EmployeeName}" Width="180"/>
                    <DataGridTextColumn Header="Dpto."       Binding="{Binding Department}"  Width="120"/>
                    <DataGridTextColumn Header="Tipo"        Binding="{Binding TypeLabel}"    Width="160"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="200"/>

                    <!-- Aprobación badge -->
                    <DataGridTemplateColumn Header="Aprobación" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2"
                                        HorizontalAlignment="Left" Margin="6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                    <Setter Property="Background" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ApprovedLabel}"
                                               FontSize="11" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Status bar ── -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Incidents.Count, StringFormat='{}{0} incidencia(s)'}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="8,0,0,0"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Height="4" HorizontalAlignment="Right" Width="120"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
